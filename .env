MSSQL_SERVER=127.0.0.1
# MSSQL_INSTANCE=SQLEXPRESS
MSSQL_DATABASE=neonine
MSSQL_USER=neonine_admin
MSSQL_PASSWORD=Neonine@2026
MSSQL_PORT=1433
MSSQL_ENCRYPT=false
MSSQL_TRUST_CERT=true
