# Port for Express API server
PORT=3000

# ─── Microsoft SQL Server Connection ─────────────────────────────────────────
MSSQL_SERVER=your-server-name
MSSQL_INSTANCE=SQLEXPRESS
MSSQL_DATABASE=neonine
MSSQL_USER=neonine_admin
MSSQL_PASSWORD=your_password
MSSQL_PORT=1433
MSSQL_ENCRYPT=false
MSSQL_TRUST_CERT=true
